# PromptForge Environment Variables
# -----------------------------------
# DO NOT put your actual API key here.
# Your API key is entered in the app's Settings panel
# and stored ONLY in your browser's localStorage.
# It is NEVER written to any file or sent to any server except the Gemini API.

# Optional: Override the default Gemini API base URL (e.g., for a proxy)
# VITE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Optional: Sentry DSN for error monitoring (Phase 3)
# VITE_SENTRY_DSN=
